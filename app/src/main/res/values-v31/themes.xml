<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 禁用系统 Splash Screen，避免系统临时 Surface 干扰 Vulkan Surface。 -->
    <style name="Theme.HSVJEngine" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="colorPrimary">@android:color/black</item>
        <item name="colorPrimaryDark">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@null</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowEnterAnimation">@null</item>
        <item name="android:windowExitAnimation">@null</item>
        <item name="android:windowActivityTransitions">false</item>
        <item name="android:windowContentTransitions">false</item>
        <item name="android:hardwareAccelerated">true</item>
    </style>
</resources>
