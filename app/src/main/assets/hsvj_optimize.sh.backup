#!/system/bin/sh
# HSVJ Engine Ultra Optimizer - 完整版
# 彻底解决 SELinux、SurfaceFlinger、性能问题
# RK3566/RK3568

# ==============================================
# SELinux 自动提权（核心）
# ==============================================
if [ "$(id -u)" -ne 0 ]; then
    echo "Need root, restarting with su..."
    exec su -c "$0" "$@"
    exit 1
fi

echo "[HSVJ] Optimizer started."
OPT_DAEMON_PID_FILE="/data/local/tmp/hsvj_optimize_daemon.pid"

# ==============================================
# SELinux 永久规则配置（最关键 - 解决 MPP 访问拒绝）
# ==============================================
configure_selinux_rules() {
    echo "[HSVJ] Configuring SELinux rules for MPP access..."

    # 方案1: 使用 supolicy 添加永久规则（最佳方案）
    if command -v supolicy >/dev/null 2>&1; then
        echo "[HSVJ] Using supolicy to inject SELinux rules..."
        supolicy --live \
            "allow system_app shell_data_file dir { search read open getattr write add_name remove_name }" \
            "allow system_app shell_data_file file { read write open getattr create unlink append }" \
            "allow system_app video_device chr_file ioctl" \
            "allow system_app video_device chr_file { read write open getattr }" \
            "allow system_app mpp_device chr_file ioctl" \
            "allow system_app mpp_device chr_file { read write open getattr }" \
            "allow system_app gpu_device chr_file ioctl" \
            "allow system_app gpu_device chr_file { read write open getattr }" \
            2>/dev/null

        if [ $? -eq 0 ]; then
            echo "[HSVJ] SELinux rules injected successfully"
            return 0
        else
            echo "[HSVJ] supolicy injection failed, trying alternative methods"
        fi
    fi

    # 方案2: 设置 Permissive 模式（兼容方案）
    if [ "$(getenforce)" = "Enforcing" ]; then
        echo "[HSVJ] Setting SELinux to Permissive mode"
        setenforce 0
        if [ $? -eq 0 ]; then
            echo "[HSVJ] SELinux set to Permissive"
        fi
    fi

    # 方案3: 修改设备节点权限（兜底方案）
    echo "[HSVJ] Updating device node permissions..."
    for dev in /dev/mpp_service /dev/mpp-service /dev/rkvdec /dev/rkvenc /dev/vepu /dev/vpu_service /dev/dri/renderD128; do
        if [ -e "$dev" ]; then
            chmod 666 "$dev" 2>/dev/null
            chown system:system "$dev" 2>/dev/null
            chcon u:object_r:video_device:s0 "$dev" 2>/dev/null
            echo "[HSVJ] Updated permissions for $dev"
        fi
    done

    # 方案4: 禁用 SELinux 审计日志（减少日志噪音）
    echo 0 > /sys/fs/selinux/enforce 2>/dev/null
    auditctl -e 0 2>/dev/null

}

# ==============================================
# SurfaceFlinger 优化（减少 Composition 错误）
# ==============================================
optimize_surfaceflinger() {
    echo "[HSVJ] Optimizing SurfaceFlinger..."

    # 禁用 SurfaceFlinger 的调试日志（减少 CompositionEngine 错误日志）
    setprop log.tag.CompositionEngine WARN
    setprop log.tag.SurfaceFlinger WARN
    setprop log.tag.BufferQueue WARN
    setprop log.tag.BufferQueueProducer WARN

    # 强制使用硬件合成
    setprop debug.sf.hw 1
    setprop debug.sf.latch_unsignaled 1

    # 禁用 VSYNC 偏移
    setprop debug.sf.disable_backpressure 1

    # 优化 GPU 渲染（使用 SkiaGL 以获得更好的视频性能）
    setprop debug.hwui.renderer skiagl
    setprop debug.renderengine.backend skiaglthreaded

    # 新增：禁用不必要的 UI 效果
    setprop debug.hwui.render_dirty_regions false
    setprop debug.hwui.show_dirty_regions false
    setprop debug.hwui.skip_empty_damage true
    setprop debug.hwui.use_buffer_age false

    # 新增：优化合成策略（减少 UI 开销）
    setprop debug.sf.max_igbp_list_size 2
    setprop debug.sf.early_phase_offset_ns 500000
    setprop debug.sf.early_gl_phase_offset_ns 500000

    # 新增：禁用动画和过渡效果（已在 optimize_dedicated_device 中设置）
    # 但在这里再次确认
    settings put global window_animation_scale 0
    settings put global transition_animation_scale 0
    settings put global animator_duration_scale 0

    echo "[HSVJ] SurfaceFlinger optimized for video playback"
}

# ==============================================
# 专机性能模式
# ==============================================
set_node_value() {
    local node="$1"
    local value="$2"
    [ -e "$node" ] || return 1
    echo "$value" > "$node" 2>/dev/null
}

lock_cpu_performance() {
    echo "[HSVJ] Locking CPU performance..."
    for policy in /sys/devices/system/cpu/cpufreq/policy*; do
        [ -d "$policy" ] || continue
        set_node_value "$policy/scaling_governor" performance
        MAX_FREQ="$(cat "$policy/cpuinfo_max_freq" 2>/dev/null)"
        [ -z "$MAX_FREQ" ] && MAX_FREQ="$(cat "$policy/scaling_available_frequencies" 2>/dev/null | awk '{print $NF}')"
        if [ -n "$MAX_FREQ" ]; then
            set_node_value "$policy/scaling_max_freq" "$MAX_FREQ"
            set_node_value "$policy/scaling_min_freq" "$MAX_FREQ"
        fi
        echo "[HSVJ] CPU $(basename "$policy") governor=$(cat "$policy/scaling_governor" 2>/dev/null) cur=$(cat "$policy/scaling_cur_freq" 2>/dev/null) min=$(cat "$policy/scaling_min_freq" 2>/dev/null) max=$(cat "$policy/scaling_max_freq" 2>/dev/null)"
    done
}

lock_devfreq_performance() {
    echo "[HSVJ] Locking GPU/VPU/DMC devfreq performance..."
    for dev in /sys/class/devfreq/*; do
        [ -d "$dev" ] || continue
        NAME="$(basename "$dev" | tr '[:upper:]' '[:lower:]')"
        case "$NAME" in
            *gpu*|*mali*|*vpu*|*vdec*|*rkvdec*|*venc*|*rkvenc*|*dmc*|*ddr*|*bus*)
                ;;
            *)
                continue
                ;;
        esac

        set_node_value "$dev/governor" performance
        MAX_FREQ="$(cat "$dev/max_freq" 2>/dev/null)"
        [ -z "$MAX_FREQ" ] && MAX_FREQ="$(cat "$dev/available_frequencies" 2>/dev/null | awk '{print $NF}')"
        if [ -n "$MAX_FREQ" ]; then
            set_node_value "$dev/max_freq" "$MAX_FREQ"
            set_node_value "$dev/min_freq" "$MAX_FREQ"
        fi
        echo "[HSVJ] DEVFREQ $NAME governor=$(cat "$dev/governor" 2>/dev/null) cur=$(cat "$dev/cur_freq" 2>/dev/null) min=$(cat "$dev/min_freq" 2>/dev/null) max=$(cat "$dev/max_freq" 2>/dev/null)"
    done
}

optimize_dedicated_device() {
    echo "[HSVJ] Applying dedicated-device performance profile..."

    lock_cpu_performance
    lock_devfreq_performance

    # 屏幕和电源设置
    settings put system screen_off_timeout 2147483647
    settings put global stay_on_while_plugged_in 3

    # 完全禁用所有动画（引擎不需要 UI 动画）
    settings put global window_animation_scale 0
    settings put global transition_animation_scale 0
    settings put global animator_duration_scale 0

    # 禁用应用待机和电池优化（确保视频播放不被打断）
    settings put global app_standby_enabled 0
    settings put global adaptive_battery_management_enabled 0
    settings put global low_power 0
    settings put global automatic_power_save_mode 0

    # 禁用省电模式的所有功能
    settings put global low_power_trigger_level 0

    # SurfaceFlinger 和 HWC 优化（专注视频性能）
    setprop debug.hwui.disable_vsync false
    setprop debug.sf.disable_backpressure 1
    setprop debug.sf.latch_unsignaled 1
    setprop debug.sf.enable_hwc_vds 1
    setprop debug.sf.enable_gl_backpressure 0
    setprop vendor.hwc.disable_skip_validate 1

    # 新增：视频播放专用优化
    setprop media.stagefright.cache-params 18432/20480/15
    setprop media.stagefright.enable-player true
    setprop media.stagefright.enable-meta true
    setprop media.stagefright.enable-scan false
    setprop media.stagefright.enable-http true
    setprop media.stagefright.use-awesome true

    # 新增：音频优化
    setprop audio.deep_buffer.media true
    setprop audio.offload.video true
    setprop audio.offload.disable false

    # 新增：禁用 UI 相关的后台服务
    settings put secure notification_badging 0
    settings put secure adaptive_sleep 0
    settings put secure camera_gesture_disabled 1
    settings put secure screensaver_enabled 0
    settings put secure accessibility_enabled 0

    # 日志降噪
    setprop log.tag.CompositionEngine WARN
    setprop log.tag.SurfaceFlinger WARN
    setprop log.tag.BufferQueue WARN
    setprop log.tag.BufferQueueProducer WARN
    setprop log.tag.AudioTrack WARN
    setprop log.tag.RKCodec WARN
    setprop log.tag.RKMpp WARN
    setprop log.tag.MppDecoder WARN
    setprop log.tag.mpp_dec_parser ERROR
    setprop log.tag.mpp_dec ERROR
    setprop log.tag.mpp_service ERROR
    setprop log.tag.mpp_dev ERROR
    setprop log.tag.mpp_device ERROR
    setprop log.tag.auditd ERROR
    setprop log.tag.audit ERROR
    setprop log.tag.rknn_server ERROR
    dmesg -n 1 2>/dev/null
    echo 1 1 1 1 > /proc/sys/kernel/printk 2>/dev/null

    # HSVJ 应用后台保护
    dumpsys deviceidle whitelist +com.hsvj.engine 2>/dev/null
    cmd appops set com.hsvj.engine RUN_IN_BACKGROUND allow 2>/dev/null
    cmd appops set com.hsvj.engine RUN_ANY_IN_BACKGROUND allow 2>/dev/null
    cmd appops set com.hsvj.engine WAKE_LOCK allow 2>/dev/null
    cmd appops set com.hsvj.engine SYSTEM_ALERT_WINDOW allow 2>/dev/null

    # 新增：内存管理优化
    # 降低 swap 倾向，优先使用物理内存
    echo 10 > /proc/sys/vm/swappiness 2>/dev/null

    # 优化脏页回写策略，减少卡顿
    echo 5 > /proc/sys/vm/dirty_background_ratio 2>/dev/null
    echo 10 > /proc/sys/vm/dirty_ratio 2>/dev/null

    # 优化 VFS 缓存压力
    echo 50 > /proc/sys/vm/vfs_cache_pressure 2>/dev/null

    # 优化 OOM killer 策略
    echo 0 > /proc/sys/vm/oom_kill_allocating_task 2>/dev/null

    # 新增：网络优化（减少不必要的网络开销）
    # 禁用 IPv6（如果不需要）
    echo 1 > /proc/sys/net/ipv6/conf/all/disable_ipv6 2>/dev/null
    echo 1 > /proc/sys/net/ipv6/conf/default/disable_ipv6 2>/dev/null

    # TCP 优化
    echo 1 > /proc/sys/net/ipv4/tcp_tw_reuse 2>/dev/null
    echo 30 > /proc/sys/net/ipv4/tcp_fin_timeout 2>/dev/null
    echo 4096 > /proc/sys/net/core/somaxconn 2>/dev/null

    # 新增：I/O 调度优化
    for disk in /sys/block/mmcblk*/queue; do
        if [ -d "$disk" ]; then
            # 使用 deadline 或 noop 调度器以减少延迟
            if [ -f "$disk/scheduler" ]; then
                echo deadline > "$disk/scheduler" 2>/dev/null || echo noop > "$disk/scheduler" 2>/dev/null
            fi
            # 优化读取预读
            echo 512 > "$disk/read_ahead_kb" 2>/dev/null
            # 禁用 I/O 统计以减少开销
            echo 0 > "$disk/iostats" 2>/dev/null
        fi
    done

    # 新增：禁用不必要的内核功能
    # 禁用内核审计
    echo 0 > /proc/sys/kernel/audit 2>/dev/null

    # 优化定时器频率
    echo 0 > /proc/sys/kernel/nmi_watchdog 2>/dev/null

    echo "[HSVJ] Dedicated-device performance profile applied"
}

# ==============================================
# 稳定优先的专机服务精简
# ==============================================
disable_optional_services() {
    echo "[HSVJ] Disabling optional services for dedicated device..."

    # 基础设置禁用
    settings put secure location_mode 0
    settings put global master_sync_enabled 0
    settings put system accelerometer_rotation 0
    dumpsys deviceidle disable 2>/dev/null

    # 禁用蓝牙（HVIDEO不需要蓝牙）
    settings put global bluetooth_on 0 2>/dev/null
    settings put global ble_scan_always_enabled 0 2>/dev/null

    # 禁用不必要的后台服务
    settings put global stay_on_while_plugged_in 3  # 充电时保持唤醒
    settings put global app_idle_enabled 0
    settings put global device_idle_constants_watch ""

    # 减少日志输出
    setprop log.tag.android.hardware.graphics.allocator-V1-service WARN
    setprop log.tag.mali_gralloc WARN
    setprop log.tag.gralloc WARN
    setprop log.tag.WifiVendorHal ERROR
    setprop log.tag.WificondScannerImpl WARN
    setprop log.tag.MediaProvider WARN
    setprop log.tag.bluetooth ERROR
    setprop log.tag.bt_btif ERROR
    setprop log.tag.BluetoothAdapterService ERROR

    safe_disable_pkg() {
        local pkg="$1"
        if pm path "$pkg" >/dev/null 2>&1; then
            pm disable-user --user 0 "$pkg" >/dev/null 2>&1 && \
                echo "[HSVJ] Disabled optional package: $pkg"
        fi
    }

    safe_force_stop_pkg() {
        local pkg="$1"
        if pm path "$pkg" >/dev/null 2>&1; then
            am force-stop "$pkg" >/dev/null 2>&1 && \
                echo "[HSVJ] Force-stopped optional package: $pkg"
        fi
    }

    # 基础应用禁用（原有）
    safe_disable_pkg android.rockchip.update.service
    safe_disable_pkg com.example.partnersupportsampletvinput
    safe_disable_pkg com.android.printspooler
    safe_disable_pkg com.android.bips
    safe_disable_pkg com.android.music
