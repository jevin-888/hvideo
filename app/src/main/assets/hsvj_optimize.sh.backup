    safe_disable_pkg com.android.screenshoteditactivity

    echo "[HSVJ] UI components deeply optimized (core kept for boot)"

# ==============================================
# 系统服务精简（停止不必要的 init 服务）
# ==============================================
disable_unnecessary_init_services() {
    echo "[HSVJ] Disabling unnecessary init services..."

    # 停止蓝牙相关服务
    stop vendor.bluetooth-1-0 2>/dev/null
    setprop ctl.stop vendor.bluetooth-1-0 2>/dev/null

    # 停止传感器服务（专机不需要）
    stop vendor.sensors-hal-1-0 2>/dev/null
    setprop ctl.stop vendor.sensors-hal-1-0 2>/dev/null

    # 停止无线电服务（专机不需要移动网络）
    stop vendor.radio-1-2 2>/dev/null
    stop vendor.radio-config-hal-1-0 2>/dev/null
    stop vendor.ril-daemon 2>/dev/null
    setprop ctl.stop vendor.radio-1-2 2>/dev/null
    setprop ctl.stop vendor.radio-config-hal-1-0 2>/dev/null
    setprop ctl.stop vendor.ril-daemon 2>/dev/null

    # 停止摄像头服务（专机不需要摄像头）
    stop cameraserver 2>/dev/null
    stop vendor.camera-provider-2-4 2>/dev/null
    stop vendor.camera-provider-2-4-ext 2>/dev/null
    setprop ctl.stop cameraserver 2>/dev/null
    setprop ctl.stop vendor.camera-provider-2-4 2>/dev/null
    setprop ctl.stop vendor.camera-provider-2-4-ext 2>/dev/null

    # 保留 DRM 服务（视频播放需要）
    # 不禁用 vendor.drm-clearkey-hal-1-3
    # 不禁用 vendor.drm-widevine-hal-1-3
    echo "[HSVJ] DRM services kept for video playback"

    # 停止 CAS 服务（条件访问系统，专机不需要）
    stop vendor.cas-hal-1-2 2>/dev/null
    setprop ctl.stop vendor.cas-hal-1-2 2>/dev/null

    # 保留 Gatekeeper 和 Keymaster（可能影响系统启动和应用验证）
    # 改为仅停止不必要的验证，但保留服务运行
    echo "[HSVJ] Gatekeeper/Keymaster kept for system stability"

    # 停止 traced（跟踪服务，专机不需要调试跟踪）
    stop traced 2>/dev/null
    stop traced_probes 2>/dev/null
    setprop ctl.stop traced 2>/dev/null
    setprop ctl.stop traced_probes 2>/dev/null

    # 停止 incident（事故报告服务）
    stop incidentd 2>/dev/null
    setprop ctl.stop incidentd 2>/dev/null

    # 停止 statsd（统计服务）
    stop statsd 2>/dev/null
    setprop ctl.stop statsd 2>/dev/null

    # 停止 mdnsd（mDNS 服务发现）
    stop mdnsd 2>/dev/null
    setprop ctl.stop mdnsd 2>/dev/null

    # 禁用系统服务的日志
    setprop log.tag.CameraService ERROR
    setprop log.tag.Camera ERROR
    setprop log.tag.BluetoothAdapterService ERROR
    setprop log.tag.BluetoothManagerService ERROR
    setprop log.tag.BluetoothGatt ERROR
    setprop log.tag.bt_btif ERROR
    setprop log.tag.bt_stack ERROR
    setprop log.tag.Sensors ERROR
    setprop log.tag.SensorService ERROR
    setprop log.tag.RadioService ERROR
    setprop log.tag.RILJ ERROR
    setprop log.tag.RIL ERROR
    setprop log.tag.Telephony ERROR

    echo "[HSVJ] Unnecessary init services disabled (core services preserved)"
}

# ==============================================
# RKNN 服务关闭
# ==============================================
disable_rknn_service() {
    RK_PLATFORM="$(cat /proc/device-tree/compatible /proc/device-tree/model /proc/cpuinfo 2>/dev/null | tr '[:upper:]' '[:lower:]')"
    case "$RK_PLATFORM" in
        *rk3566*|*rk3568*)
            ;;
        *)
            echo "[HSVJ] RKNN service kept for non-RK3566/RK3568 platform"
            return 0
            ;;
    esac

    echo "[HSVJ] Disabling RKNN service..."

    stop rknn_server 2>/dev/null
    stop rknnserver 2>/dev/null
    pkill -f rknn_server 2>/dev/null
    pkill -f rknnserver 2>/dev/null

    setprop ctl.stop rknn_server 2>/dev/null
    setprop ctl.stop rknnserver 2>/dev/null

    if pidof rknn_server >/dev/null 2>&1 || pidof rknnserver >/dev/null 2>&1; then
        echo "[HSVJ] RKNN service still running"
    else
        echo "[HSVJ] RKNN service stopped"
    fi
}

# ==============================================
# 清理系统缓存和临时文件
# ==============================================
cleanup_system_cache() {
    echo "[HSVJ] Cleaning system cache and temporary files..."

    # 清理 logcat 缓冲区
    logcat -c 2>/dev/null

    # 清理 tombstone 文件（崩溃日志）
    rm -rf /data/tombstones/* 2>/dev/null

    # 清理 ANR 日志
    rm -rf /data/anr/* 2>/dev/null

    # 清理系统日志
    rm -rf /data/system/dropbox/* 2>/dev/null

    # 清理临时文件
    rm -rf /data/local/tmp/*.tmp 2>/dev/null
    rm -rf /data/local/tmp/*.log 2>/dev/null

    # 清理不必要应用的缓存（但保留 HSVJ）
    for pkg in $(pm list packages -e | cut -d: -f2 | grep -v "hsvj\|systemui\|launcher"); do
        # 只清理非核心应用的缓存
        case "$pkg" in
            com.android.bluetooth|com.android.phone|com.android.server.telecom|com.android.location.fused)
                pm clear "$pkg" 2>/dev/null
                echo "[HSVJ] Cleared cache for $pkg"
                ;;
        esac
    done

    # 清理 shader 缓存（排除 HSVJ）
    for shader_dir in /data/user_de/0/*/code_cache/com.android.*/shader_cache; do
        if ! echo "$shader_dir" | grep -q "hsvj"; then
            rm -rf "$shader_dir"/* 2>/dev/null
        fi
    done

    echo "[HSVJ] System cache cleaned"
}

# ==============================================
# PackageManager 安装残留清理
# ==============================================
cleanup_package_install_residue() {
    echo "[HSVJ] Cleaning package install staging residue..."

    # PackageManager 也会使用 /data/app/vmdl*.tmp 作为活动安装会话目录。
    # 如果在这里移除新的会话目录，可能导致 install-commit 失败并出现
    # INSTALL_FAILED_INVALID_APK，因此只删除明确陈旧的残留目录。
    STALE_SECONDS="${HSVJ_INSTALL_STAGING_STALE_SECONDS:-86400}"
    NOW_SECONDS="$(date +%s 2>/dev/null)"
    REMOVED_COUNT=0
    FREED_KB=0
    for dir in /data/app/vmdl*.tmp; do
        [ -d "$dir" ] || continue

        case "$dir" in
            /data/app/vmdl*.tmp)
                ;;
            *)
                echo "[HSVJ] Skip unexpected staging path: $dir"
                continue
                ;;
        esac

        DIR_MTIME="$(stat -c %Y "$dir" 2>/dev/null)"
        if [ -z "$NOW_SECONDS" ] || [ -z "$DIR_MTIME" ]; then
            echo "[HSVJ] Skip staging dir without reliable age: $dir"
            continue
        fi

        AGE_SECONDS=$((NOW_SECONDS - DIR_MTIME))
        if [ "$AGE_SECONDS" -lt "$STALE_SECONDS" ]; then
            echo "[HSVJ] Skip active/recent package staging dir: $dir age=${AGE_SECONDS}s threshold=${STALE_SECONDS}s"
            continue
        fi

        SIZE_KB="$(du -sk "$dir" 2>/dev/null | awk '{print $1}')"
        [ -n "$SIZE_KB" ] || SIZE_KB=0
        echo "[HSVJ] Removing stale package staging dir: $dir age=${AGE_SECONDS}s (${SIZE_KB}KB)"

        rm -rf "$dir" 2>/dev/null
        if [ -e "$dir" ]; then
            echo "[HSVJ] Failed to remove staging dir: $dir"
        else
            REMOVED_COUNT=$((REMOVED_COUNT + 1))
            FREED_KB=$((FREED_KB + SIZE_KB))
        fi
    done

    echo "[HSVJ] Package staging cleanup done: removed=${REMOVED_COUNT}, freed=${FREED_KB}KB"
}

schedule_package_install_residue_cleanup() {
    DELAY_SECONDS="${HSVJ_INSTALL_STAGING_CLEANUP_DELAY_SECONDS:-180}"
    echo "[HSVJ] Package staging cleanup scheduled after ${DELAY_SECONDS}s."
    (
        sleep "$DELAY_SECONDS"
        cleanup_package_install_residue
    ) &
}

# ==============================================
# 基础优化
# ==============================================
base_optimize() {
    # OOM 保护
    protect_app_oom

    # RKVDEC 硬件解码器锁定最高频率（400MHz），避免 vdec2_ondemand 调频延迟导致 4K 解码卡顿
    RKVDEC_DEVFREQ="/sys/class/devfreq/fdf80200.rkvdec"
    if [ -d "$RKVDEC_DEVFREQ" ]; then
        echo performance > "$RKVDEC_DEVFREQ/governor" 2>/dev/null
        MAX_FREQ=$(cat "$RKVDEC_DEVFREQ/max_freq" 2>/dev/null)
        if [ -n "$MAX_FREQ" ]; then
            echo "$MAX_FREQ" > "$RKVDEC_DEVFREQ/min_freq" 2>/dev/null
        fi
        echo "[HSVJ] RKVDEC governor: $(cat $RKVDEC_DEVFREQ/governor 2>/dev/null), freq: $(cat $RKVDEC_DEVFREQ/cur_freq 2>/dev/null)"
    else
        echo "[HSVJ] RKVDEC devfreq node not found, skipping"
    fi

    # 强制全屏
    settings put global policy_control immersive.full=*

    # 日志降噪
    setprop log.tag.V4L2DeviceDetector WARN
    setprop log.tag.CompositionEngine WARN
    setprop log.tag.mpp_dec_parser ERROR
    setprop log.tag.mpp_dec ERROR
    setprop log.tag.mpp_service ERROR
    setprop log.tag.mpp_dev ERROR
    setprop log.tag.mpp_device ERROR
    setprop log.tag.auditd ERROR
    setprop log.tag.audit ERROR

    # 端口转发 80 -> 8080（只绑定当前 eth0 IP，避免旧 IP 的 ARP 缓存继续命中本机服务）
    while true; do
        line="$(iptables -t nat -L PREROUTING --line-numbers -n 2>/dev/null | awk '/tcp dpt:80 redir ports 8080/ {print $1; exit}')"
        [ -n "$line" ] || break
        iptables -t nat -D PREROUTING "$line" 2>/dev/null || break
    done
    eth_ip="$(ip -4 -o addr show dev eth0 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -n 1)"
    if [ -n "$eth_ip" ]; then
        iptables -t nat -A PREROUTING -d "$eth_ip"/32 -p tcp --dport 80 -j REDIRECT --to-port 8080
    fi

    # 清理缓存
    :
}

# ==============================================
# 系统终极精简（全部可卸载应用，一次性清理）
# ==============================================
uninstall_bloatware() {
    echo "[HSVJ] Uninstalling all useless system apps..."

    # 谷歌与浏览器
    pm uninstall --user 0 com.google.android.webview
    pm uninstall --user 0 com.google.android.tts
    pm uninstall --user 0 com.android.chrome

    # 打印相关
    pm uninstall --user 0 com.android.printspooler
    pm uninstall --user 0 com.android.bips

    # 录音
    pm uninstall --user 0 com.android.soundrecorder

    # 壁纸、动态壁纸、屏保（彻底删除）
    # ==============================================
    pm uninstall --user 0 com.android.wallpaperpicker          # 静态壁纸选择器
    pm uninstall --user 0 com.android.wallpaper.livepicker    # 动态壁纸选择器
    pm uninstall --user 0 com.android.dreams.basic            # 系统屏保（Daydream）
    pm uninstall --user 0 com.android.dreams.phototable       # 照片屏保
    pm uninstall --user 0 com.android.wallpaper               # 壁纸服务/ThemePicker（部分系统）
    pm uninstall --user 0 com.android.theme.wallpaper         # 主题壁纸组件

    # 日常应用
    pm uninstall --user 0 com.android.music
    pm uninstall --user 0 com.android.musicfx
    pm uninstall --user 0 com.android.gallery3d
    pm uninstall --user 0 com.android.calculator2
    pm uninstall --user 0 com.android.deskclock
    pm uninstall --user 0 com.android.contacts
    pm uninstall --user 0 com.android.calendar
    pm uninstall --user 0 com.android.egg

    # 测试与工具
    pm uninstall --user 0 com.cghs.stresstest
    pm uninstall --user 0 com.DeviceTest
    pm uninstall --user 0 com.ebanswers.aotoshutdown
    pm uninstall --user 0 com.lztek.autoboot

    # 加入系统白名单，永不休眠、永不限制
    dumpsys deviceidle whitelist +com.hsvj.engine

    # 关闭电池优化 & 后台限制
    settings put global app_standby_enabled 0
    settings put secure allowed_background_apps com.hsvj.engine

    # 允许安装后自动运行、禁止系统拦截
    pm set-app-standby-enabled com.hsvj.engine false
    pm dontkill com.hsvj.engine

    # 通信类
    # pm uninstall --user 0 com.android.nfc
    # pm uninstall --user 0 com.android.providers.telephony
    # pm uninstall --user 0 com.android.mms.service
    # pm uninstall --user 0 com.android.smspush

    # 测试与代理
    # pm uninstall --user 0 com.android.cts.priv.ctsshim
    # pm uninstall --user 0 com.android.cts.ctsshim
    # pm uninstall --user 0 com.android.pacprocessor
    # pm uninstall --user 0 com.android.proxyhandler

    # 文件管理、系统播放器
    pm uninstall --user 0 com.android.documentsui
    pm uninstall --user 0 android.rk.RockVideoPlayer

    # 刘海/屏幕切口
    pm uninstall --user 0 com.android.internal.display.cutout.emulation.corner
    pm uninstall --user 0 com.android.internal.display.cutout.emulation.double
    pm uninstall --user 0 com.android.internal.display.cutout.emulation.hole
    pm uninstall --user 0 com.android.internal.display.cutout.emulation.tall
    pm uninstall --user 0 com.android.internal.display.cutout.emulation.waterfall

    # 杂项
    # pm uninstall --user 0 com.android.htmlviewer
    # pm uninstall --user 0 com.android.soundpicker
    # pm uninstall --user 0 com.android.dynsystem
    # pm uninstall --user 0 com.android.bookmarkprovider
    # pm uninstall --user 0 com.android.providers.partnerbookmarks
    # pm uninstall --user 0 com.android.onetimeinitializer
    # pm uninstall --user 0 com.android.traceur
    # pm uninstall --user 0 com.rockchip.wfd
    # pm uninstall --user 0 com.android.simappdialog
    # pm uninstall --user 0 com.android.carrierdefaultapp
    # pm uninstall --user 0 com.android.carrierconfig
}

# ==============================================
# 内存自动维护
# ==============================================
drop_caches() {
    echo "[HSVJ] Low memory, dropping page cache..."
    sync
    echo 1 > /proc/sys/vm/drop_caches 2>/dev/null
}

startup_memory_trim() {
    echo "[HSVJ] Startup memory trim..."
    # HSVJ 可能已经在播放视频时，不要释放页缓存。
    # 优化脚本由 MainActivity 异步启动；强制释放缓存
    # 如果发生在播放期间，可能卡住文件 IO 并干扰 MPP/Vulkan 时序。
    :
}

protect_app_oom() {
    APP_PID=$(pidof com.hsvj.engine)
    if [ -n "$APP_PID" ]; then
        for PID in $APP_PID; do
            echo -1000 > /proc/$PID/oom_score_adj 2>/dev/null
            CUR_OOM="$(cat /proc/$PID/oom_score_adj 2>/dev/null)"
            log -t HSVJ_OPT "OOM protect PID:$PID score:$CUR_OOM"
        done
    fi
}

check_memory() {
    FREE_MEM=$(cat /proc/meminfo | awk '/MemFree/{print $2}')
    # 只在可用内存低于 40MB 时才清理，避免频繁 drop_caches 造成视频读盘卡顿
    [ "$FREE_MEM" -lt 40960 ] && drop_caches
}

# ==============================================
# 轻量守护
# ==============================================
daemon() {
    local count=0
    while true; do
        protect_app_oom
        check_memory
        if pidof rknn_server >/dev/null 2>&1 || pidof rknnserver >/dev/null 2>&1; then
            disable_rknn_service
        fi
        count=$((count+1))
        # 每 20 次（约 10 分钟）才强制清理一次，减少对运行中应用的干扰
        [ $count -ge 20 ] && { count=0; }
        sleep 30
    done
}

# ==============================================
# 主执行流程
# ==============================================
echo "[HSVJ] Starting optimization sequence..."

# 1. 最关键：配置 SELinux 规则（解决 MPP 访问拒绝）
configure_selinux_rules

# 2. 延迟清理 PackageManager 安装残留，避免刚安装/更新时碰到 active install session
schedule_package_install_residue_cleanup

# 3. 优化 SurfaceFlinger（减少 Composition 错误）
optimize_surfaceflinger

# 4. RK3566/RK3568 关闭 RKNN 服务，RK3588 保持可用
disable_rknn_service

# 4.5 禁用不必要的 init 服务
disable_unnecessary_init_services

# 5. 启动前轻量内存清理
startup_memory_trim

# 6. 专机性能模式
optimize_dedicated_device

# 7. 稳定优先的可选服务精简
disable_optional_services

# 7.5 清理系统缓存
cleanup_system_cache

# 8. 基础优化
base_optimize

# 9. 系统精简必须离线执行；运行中卸载/停系统包会抢 IO/CPU，影响正在播放的视频。
echo "[HSVJ] Runtime optimizer skips uninstall_bloatware"

# 10. 启动守护进程
OLD_OPT_DAEMON_PID="$(cat "$OPT_DAEMON_PID_FILE" 2>/dev/null)"
if [ -n "$OLD_OPT_DAEMON_PID" ] && [ -d "/proc/$OLD_OPT_DAEMON_PID" ]; then
    OLD_CMDLINE="$(tr '\0' ' ' < /proc/$OLD_OPT_DAEMON_PID/cmdline 2>/dev/null)"
    if echo "$OLD_CMDLINE" | grep -q "hsvj_optimize.sh"; then
        echo "[HSVJ] Stopping old optimizer daemon pid=$OLD_OPT_DAEMON_PID."
        kill "$OLD_OPT_DAEMON_PID" 2>/dev/null
        sleep 1
    fi
fi
daemon &
echo "$!" > "$OPT_DAEMON_PID_FILE"

echo "[HSVJ] =========================================="
echo "[HSVJ] System fully optimized!"
echo "[HSVJ] =========================================="
echo "[HSVJ] SELinux: $(getenforce)"
echo "[HSVJ] App PID: $(pidof com.hsvj.engine)"
echo "[HSVJ] OOM Score: $(cat /proc/$(pidof com.hsvj.engine)/oom_score_adj 2>/dev/null || echo 'N/A')"
echo "[HSVJ] =========================================="
echo "[HSVJ] Memory Status:"
echo "[HSVJ]   Total: $(cat /proc/meminfo | grep MemTotal | awk '{print $2}') KB"
echo "[HSVJ]   Free: $(cat /proc/meminfo | grep MemFree | awk '{print $2}') KB"
echo "[HSVJ]   Available: $(cat /proc/meminfo | grep MemAvailable | awk '{print $2}') KB"
echo "[HSVJ] =========================================="
echo "[HSVJ] CPU Governor:"
for policy in /sys/devices/system/cpu/cpufreq/policy*; do
    [ -d "$policy" ] && echo "[HSVJ]   $(basename $policy): $(cat $policy/scaling_governor 2>/dev/null) @ $(cat $policy/scaling_cur_freq 2>/dev/null) Hz"
done
echo "[HSVJ] =========================================="
echo "[HSVJ] GPU/VPU Status:"
for dev in /sys/class/devfreq/*; do
    [ -d "$dev" ] || continue
    NAME="$(basename "$dev")"
    case "$NAME" in
        *gpu*|*mali*|*vpu*|*vdec*|*rkvdec*)
            echo "[HSVJ]   $NAME: $(cat $dev/governor 2>/dev/null) @ $(cat $dev/cur_freq 2>/dev/null) Hz"
            ;;
    esac
done
echo "[HSVJ] =========================================="
echo "[HSVJ] Disabled Services:"
echo "[HSVJ]   - Bluetooth (bluetooth-1-0)"
echo "[HSVJ]   - Camera (cameraserver)"
echo "[HSVJ]   - Radio/Telephony (radio-1-2, ril-daemon)"
echo "[HSVJ]   - Sensors (sensors-hal-1-0)"
echo "[HSVJ]   - RKNN (rknn_server)"
echo "[HSVJ]   - Location (location.fused)"
echo "[HSVJ]   - Traced (traced, traced_probes)"
echo "[HSVJ]   - Statsd (statsd)"
echo "[HSVJ] =========================================="
echo "[HSVJ] Preserved for Stability:"
echo "[HSVJ]   ✓ DRM services (video playback)"
echo "[HSVJ]   ✓ Gatekeeper/Keymaster (system security)"
echo "[HSVJ]   ✓ SystemUI core (system boot)"
echo "[HSVJ]   ✓ Input method (basic input)"
echo "[HSVJ]   ✓ Navigation (gesture/buttons)"
echo "[HSVJ] =========================================="
echo "[HSVJ] Optimizations Applied:"
echo "[HSVJ]   ✓ CPU locked to performance mode"
echo "[HSVJ]   ✓ GPU/VPU/DMC locked to max frequency"
echo "[HSVJ]   ✓ SELinux configured for MPP access"
echo "[HSVJ]   ✓ SurfaceFlinger optimized"
echo "[HSVJ]   ✓ Memory management tuned"
echo "[HSVJ]   ✓ I/O scheduler optimized"
echo "[HSVJ]   ✓ Network stack tuned"
echo "[HSVJ]   ✓ System cache cleaned"
echo "[HSVJ]   ✓ 50+ unused packages disabled"
echo "[HSVJ]   ✓ All theme packages disabled"
echo "[HSVJ]   ✓ Background daemon running"
echo "[HSVJ] =========================================="
