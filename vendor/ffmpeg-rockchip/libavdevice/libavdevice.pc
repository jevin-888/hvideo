prefix=/mnt/d/Hvideo/Third-Party/ffmpeg-rockchip/android/arm64
exec_prefix=${prefix}
libdir=/mnt/d/Hvideo/Third-Party/ffmpeg-rockchip/android/arm64/lib
includedir=/mnt/d/Hvideo/Third-Party/ffmpeg-rockchip/android/arm64/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 60.3.100
Requires: 
Requires.private: libavfilter >= 9.12.100, libswscale >= 7.5.100, libpostproc >= 57.3.100, libavformat >= 60.16.100, libavcodec >= 60.31.102, libswresample >= 4.12.100, libavutil >= 58.29.100
Conflicts:
Libs: -L${libdir}  -lavdevice 
Libs.private: -lm -latomic -landroid -lcamera2ndk -lmediandk -pthread -L/mnt/d/Hvideo/Third-Party/ffmpeg-rockchip/../libdrm-android/lib -ldrm
Cflags: -I${includedir}
