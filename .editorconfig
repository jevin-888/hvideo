# EditorConfig 配置文件 - 统一编码规范，防止中文乱码
# https://editorconfig.org

root = true

# 所有文件的默认设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ 源文件
[*.{c,cpp,cc,cxx,h,hpp}]
charset = utf-8
indent_style = space
indent_size = 4

# Java 文件
[*.java]
charset = utf-8
indent_style = space
indent_size = 4

# Kotlin 文件
[*.kt]
charset = utf-8
indent_style = space
indent_size = 4

# Python 文件
[*.py]
charset = utf-8
indent_style = space
indent_size = 4

# Shell 脚本
[*.sh]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2

# Markdown 文档
[*.md]
charset = utf-8
trim_trailing_whitespace = false

# JSON 文件
[*.json]
charset = utf-8
indent_style = space
indent_size = 2

# XML 文件
[*.xml]
charset = utf-8
indent_style = space
indent_size = 4

# Gradle 文件
[*.gradle]
charset = utf-8
indent_style = space
indent_size = 4

# CMake 文件
[CMakeLists.txt]
charset = utf-8
indent_style = space
indent_size = 4

# 字幕文件
[*.{ass,srt,lrc}]
charset = utf-8

# JavaScript/TypeScript
[*.{js,ts}]
charset = utf-8
indent_style = space
indent_size = 2

# CSS
[*.css]
charset = utf-8
indent_style = space
indent_size = 2

# HTML
[*.html]
charset = utf-8
indent_style = space
indent_size = 2
